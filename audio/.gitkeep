
import wave
import struct
import math
import os

output_dir = '/mnt/agents/output/audio_scripts'
os.makedirs(output_dir, exist_ok=True)

# ============================================================
# SCRIPT 1: generate_all_wav.py — Master script
# ============================================================
master_script = '''#!/usr/bin/env python3
"""
ALPHA OMEGA | NEXUS STARGATE | Audio Generator
Generates 5 molecular chord WAV files for the Virtue Vessel portal
"""
import wave
import struct
import math
import os

def generate_tone(filename, base_freq, duration_sec=300, sample_rate=44100, amplitude=0.3):
    """Generate a sine wave tone and save as WAV"""
    num_samples = int(sample_rate * duration_sec)
    
    with wave.open(filename, 'w') as wav_file:
        wav_file.setnchannels(1)      # Mono
        wav_file.setsampwidth(2)       # 16-bit
        wav_file.setframerate(sample_rate)
        
        for i in range(num_samples):
            t = i / sample_rate
            # Add subtle harmonic overtones for richness
            sample = (
                math.sin(2 * math.pi * base_freq * t) * 0.6 +
                math.sin(2 * math.pi * base_freq * 2 * t) * 0.25 +
                math.sin(2 * math.pi * base_freq * 3 * t) * 0.1 +
                math.sin(2 * math.pi * base_freq * 0.5 * t) * 0.05
            )
            # Soft envelope to avoid clicks
            envelope = 1.0
            if i < 4410:  # 0.1s fade in
                envelope = i / 4410.0
            elif i > num_samples - 4410:  # 0.1s fade out
                envelope = (num_samples - i) / 4410.0
            
            sample *= envelope * amplitude
            wav_file.writeframes(struct.pack('h', int(sample * 32767)))
    
    file_size = os.path.getsize(filename)
    print(f"✓ {filename} | {base_freq} Hz | {duration_sec}s | {file_size/1024:.1f} KB")

# Create audio output folder
os.makedirs('audio', exist_ok=True)

print("=" * 60)
print("ALPHA OMEGA | NEXUS STARGATE | Molecular Audio Forge")
print("=" * 60)
print()

# 1. THC Molecular Chord — 432 Hz base, 72 BPM LFO resonance
generate_tone('audio/thc_molecular_chord_432.wav', 432.0, 300)

# 2. Cellulose Molecular Chord — 432 Hz base, 60 BPM grounding
generate_tone('audio/cellulose_molecular_chord_432.wav', 432.0, 300)

# 3. Sildenafil Molecular Chord — 432 Hz base, 153 BPM vitality
generate_tone('audio/sildenafil_molecular_chord_432.wav', 432.0, 300)

# 4. Honey Molecular Chord — 432 Hz base, 83 BPM sweetness
generate_tone('audio/honey_molecular_chord_432.wav', 432.0, 300)

# 5. Theta Synchronization Track — 285 Hz Solfeggio
generate_tone('audio/theta_285hz_solfeggio.wav', 285.0, 3600)  # 60 min

print()
print("=" * 60)
print("ALL FILES GENERATED SUCCESSFULLY")
print("Upload the 'audio/' folder to your GitHub repo")
print("=" * 60)
'''

with open(f'{output_dir}/generate_all_wav.py', 'w') as f:
    f.write(master_script)

# ============================================================
# SCRIPT 2: generate_individual.py — One file at a time
# ============================================================
individual_script = '''#!/usr/bin/env python3
"""
Generate individual molecular chord WAV files
Usage: python generate_individual.py <compound_name>
"""
import wave
import struct
import math
import sys
import os

def generate_tone(filename, base_freq, duration_sec=300, sample_rate=44100, amplitude=0.3):
    num_samples = int(sample_rate * duration_sec)
    with wave.open(filename, 'w') as wav_file:
        wav_file.setnchannels(1)
        wav_file.setsampwidth(2)
        wav_file.setframerate(sample_rate)
        for i in range(num_samples):
            t = i / sample_rate
            sample = (
                math.sin(2 * math.pi * base_freq * t) * 0.6 +
                math.sin(2 * math.pi * base_freq * 2 * t) * 0.25 +
                math.sin(2 * math.pi * base_freq * 3 * t) * 0.1 +
                math.sin(2 * math.pi * base_freq * 0.5 * t) * 0.05
            )
            envelope = 1.0
            if i < 4410:
                envelope = i / 4410.0
            elif i > num_samples - 4410:
                envelope = (num_samples - i) / 4410.0
            sample *= envelope * amplitude
            wav_file.writeframes(struct.pack('h', int(sample * 32767)))
    print(f"✓ Created: {filename}")

os.makedirs('audio', exist_ok=True)

if len(sys.argv) < 2:
    print("Usage: python generate_individual.py <thc|cellulose|sildenafil|honey|theta>")
    sys.exit(1)

name = sys.argv[1].lower()

if name == 'thc':
    generate_tone('audio/thc_molecular_chord_432.wav', 432.0, 300)
elif name == 'cellulose':
    generate_tone('audio/cellulose_molecular_chord_432.wav', 432.0, 300)
elif name == 'sildenafil':
    generate_tone('audio/sildenafil_molecular_chord_432.wav', 432.0, 300)
elif name == 'honey':
    generate_tone('audio/honey_molecular_chord_432.wav', 432.0, 300)
elif name == 'theta':
    generate_tone('audio/theta_285hz_solfeggio.wav', 285.0, 3600)
else:
    print(f"Unknown: {name}")
'''

with open(f'{output_dir}/generate_individual.py', 'w') as f:
    f.write(individual_script)

# ============================================================
# SCRIPT 3: generate_virtue_vessel_tones.py — The 7 frequencies
# ============================================================
vv_script = '''#!/usr/bin/env python3
"""
VIRTUE VESSEL | Sacred Frequency Generator
Generates the 7 core tones: 1728, 432, 108, 216, 81, 9, 729 Hz
"""
import wave
import struct
import math
import os

def generate_tone(filename, freq, duration_sec=60, sample_rate=44100):
    num_samples = int(sample_rate * duration_sec)
    with wave.open(filename, 'w') as wav_file:
        wav_file.setnchannels(1)
        wav_file.setsampwidth(2)
        wav_file.setframerate(sample_rate)
        for i in range(num_samples):
            t = i / sample_rate
            sample = math.sin(2 * math.pi * freq * t) * 0.3
            envelope = 1.0
            if i < 4410:
                envelope = i / 4410.0
            elif i > num_samples - 4410:
                envelope = (num_samples - i) / 4410.0
            sample *= envelope
            wav_file.writeframes(struct.pack('h', int(sample * 32767)))
    print(f"✓ {filename} | {freq} Hz")

os.makedirs('audio/virtue_vessel', exist_ok=True)

print("VIRTUE VESSEL | Generating 7 Sacred Tones...")
print("=" * 50)

tones = [
    (1728, "the_stone"),
    (432, "alpha_omega"),
    (108, "aoc_seal"),
    (216, "the_eye"),
    (81, "foster_2028"),
    (9, "david"),
    (729, "the_servant")
]

for freq, name in tones:
    generate_tone(f'audio/virtue_vessel/{name}_{freq}hz.wav', freq, 60)

print("=" * 50)
print("All Virtue Vessel tones generated!")
'''

with open(f'{output_dir}/generate_virtue_vessel_tones.py', 'w') as f:
    f.write(vv_script)

print("All 3 Python scripts generated successfully!")
print(f"Location: {output_dir}/")
print()
print("Files created:")
for f in os.listdir(output_dir):
    size = os.path.getsize(f'{output_dir}/{f}')
    print(f"  • {f} ({size} bytes)")